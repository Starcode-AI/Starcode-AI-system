APP_NAME=LocalAI Control
APP_ENV=development
DATABASE_URL=sqlite:///data/localai.db
SECRET_KEY=replace-with-at-least-32-random-characters
SEARXNG_SECRET=replace-with-a-separate-random-secret
ALLOWED_HOSTS=localhost,127.0.0.1
TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000
FORCE_HTTPS=false
SESSION_HOURS=24
MAX_LOGIN_ATTEMPTS=6
LOGIN_LOCK_MINUTES=15
REQUEST_RATE_PER_MINUTE=120

OLLAMA_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5-coder:7b
MODEL_CONTEXT_LENGTH=8192
MODEL_TEMPERATURE=0.2
MODEL_MAX_TOKENS=2048

SEARXNG_URL=http://127.0.0.1:8080
RESEARCH_MAX_RESULTS=6
RESEARCH_MAX_PAGES=5
RESEARCH_TIMEOUT_SECONDS=12
RESEARCH_MAX_DOWNLOAD_MB=8

UPLOAD_DIR=data/uploads
PROJECT_DIR=data/projects
BACKUP_DIR=data/backups
MAX_UPLOAD_GB=5
ARCHIVE_MAX_FILES=5000
ARCHIVE_MAX_EXPANDED_GB=10
ARCHIVE_MAX_DEPTH=2
CLAMAV_HOST=
CLAMAV_PORT=3310

# Optional one-time bootstrap. Prefer: python -m scripts.create_admin
BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_ADMIN_PASSWORD=
